*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
.env
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.parquet
.DS_Store
.ipynb_checkpoints/
*.log
