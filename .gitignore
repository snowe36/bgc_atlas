# Data (large; regenerate with np-download)
data/raw/*
data/processed/*
!data/.gitkeep
!data/raw/.gitkeep
!data/processed/.gitkeep

# Figures regenerated by pipeline
reports/figures/*.png
reports/figures/*.pdf
reports/figures/*.svg
reports/*.csv
!reports/figures/.gitkeep

